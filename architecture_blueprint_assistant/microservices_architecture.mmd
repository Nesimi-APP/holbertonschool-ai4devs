graph TD
    Client([Mobile/Web Client]) --> Gateway[API Gateway]
    
    subgraph "Core Services"
        Gateway --> Auth[Auth Service]
        Gateway --> Ride[Ride Management Service]
        Gateway --> Match[Driver Dispatch Service]
        Gateway --> Pay[Transaction & Billing Service]
        Gateway --> Review[Reputation Service]
    end

    subgraph "Infrastructure & Async"
        Gateway --> Notify[Notification Dispatcher]
        Ride -- "Event: RideCreated" --> Match
        Pay -- "Event: PaymentSuccess" --> Notify
        Ride -- "Event: RideCompleted" --> Pay
        
        Events{Message Broker}
        Ride -.-> Events
        Pay -.-> Events
        Events -.-> Analytics[Data Warehouse Analytics]
    end

    Auth --- AuthDB[(Identity Store)]
    Ride --- RideDB[(Ride State Store)]
    Pay --- PayDB[(Ledger Store)]
    Review --- RevDB[(Review Store)]
